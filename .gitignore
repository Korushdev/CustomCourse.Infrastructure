# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data, such as
# password, private keys, and other secrets. These should not be part of version 
# control as they are data based. For more information, see:
# https://www.terraform.io/docs/language/values/variables.html#variable-definitions-.tfvars-files
*.tfvars
*.tfvars.json

# Ignore override files as they are usually used to override resources locally and so
# are not checked in
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Include override files you do want to add to version control using !
# !example_override.tf

# Include plugin cache directories
.terraform.lock.hcl

.vs
.idea
bin
obj
debug.log
.vscode
*.sln.user
.DS_Store
*.sln.DotSettings.user
*.csproj.user
.env
.idea/
